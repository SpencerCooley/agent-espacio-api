# Agent Espacio API Environment Configuration
# Copy this file to .env and update values

# PostgreSQL Configuration
POSTGRES_USER=agentespacio
POSTGRES_PASSWORD=agentespacio
POSTGRES_DB=agentespacio_db
POSTGRES_PORT=5432

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# API Configuration
API_HOST=0.0.0.0
