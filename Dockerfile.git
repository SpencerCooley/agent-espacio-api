FROM alpine:3.19

RUN apk add --no-cache \
    git \
    openssh-server \
    bash \
    postgresql-client

RUN adduser -D -s /usr/bin/git-shell git && \
    sed -i 's/^git:!/git:*/' /etc/shadow && \
    mkdir -p /home/git/.ssh && \
    chown git:git /home/git/.ssh && \
    chmod 700 /home/git/.ssh

RUN ln -s /repos /home/git/repos

RUN git config --system --add safe.directory '*'

# Keep sshd_config outside /etc/ssh so the git_host_keys volume does not shadow it
RUN mkdir -p /usr/local/etc
COPY config/sshd_config /usr/local/etc/sshd_config
COPY scripts/ssh-auth.sh /usr/local/bin/ssh-auth.sh
RUN chmod 755 /usr/local/bin/ssh-auth.sh

EXPOSE 22

# Capture Compose env before sshd starts (sshd clears process environ)
CMD ["sh", "-c", "printenv | grep '^POSTGRES_' > /etc/git-auth.env; chmod 600 /etc/git-auth.env; if [ ! -f /etc/ssh/ssh_host_rsa_key ]; then ssh-keygen -A; fi; exec /usr/sbin/sshd -D -e -f /usr/local/etc/sshd_config"]
